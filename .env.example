# Database
# Add ?sslmode=verify-full to suppress SSL warning (e.g. postgresql://user:pass@host:5432/db?sslmode=verify-full)
DATABASE_URL="postgresql://..."

# Authentication
# Use NEXTAUTH_URL only (base URL, no path). Do NOT set AUTH_URL – it can cause "UnknownAction" on sign-in.
# For local dev use localhost only (no ngrok) so cookies and callback URL match.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="..."
AUTH_SECRET="..."
# Optional: comma-separated emails that skip the waitlist (set to active on first sign-in and on each login).
# Use for owner/dev accounts. Treat like a secret in production (who can log in fully).
# AUTO_ACTIVATE_SIGN_IN_EMAILS="you@company.com,other@company.com"

# OAuth
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."

# AI – recommended: Gemini (chat + RAG embeddings, one key, lower cost)
GOOGLE_GENERATIVE_AI_API_KEY="..."

# Optional: USE_MOCK_LLM=true → mock responses (no API calls; for tests / dev)
# Optional: LLM_PROVIDER=gemini → force Gemini even if only GOOGLE_GENERATIVE_AI_API_KEY is set
# Optional: LLM_PROVIDER=lmstudio → local LM Studio (bypasses AI Gateway even if key is set)

# Fallback: Anthropic for chat when Gemini is unavailable; Perplexity for research
ANTHROPIC_API_KEY="..."

# AI Gateway (optional): Vercel AI Gateway for unified token spend tracking (chat + embeddings).
# When set, text routing follows: explicit gateway model -> channel hint -> tier default.
# Generated image/video assets also require AI_GATEWAY_API_KEY and use the model ids below.
# LM Studio still bypasses Gateway entirely when LLM_PROVIDER=lmstudio.
# BYOK provider credentials are configured in the Vercel dashboard, not in this file.
# Get a key at https://vercel.com/docs/ai-gateway/getting-started
# AI_GATEWAY_API_KEY=""
# Optional: override the default AI Gateway media models used by generated_image/generated_video.
# GATEWAY_IMAGE_MODEL="google/gemini-3-pro-image"
# GATEWAY_VIDEO_MODEL="google/veo-3.1-generate-001"

# External services (used by Expansion agent and Settings status)
# Required for full agent: RESEND, CAL, APOLLO, PERPLEXITY
# Optional: FIRECRAWL (Content Library – Import from URL & Sync NVIDIA Content)
# Get an API key at https://www.firecrawl.dev (sign up → API Keys). Keys start with fc-
# Required for: Import from URL, Sync NVIDIA Content (GTC sessions, industry pages)
RESEND_API_KEY="re_..."
RESEND_FROM="onboarding@resend.dev"
RESEND_WEBHOOK_SECRET=""
APOLLO_API_KEY="..."
CAL_API_KEY="..."
CAL_EVENT_TYPE_ID="123456"
CAL_WEBHOOK_SECRET=""
# Optional: your public "book a meeting" page (e.g. https://cal.com/your-username) for "let them pick a time"
CAL_PUBLIC_BOOKING_URL=""
# Optional: marketing "Book a Demo" link (defaults to Calendly in app/page.tsx if unset)
NEXT_PUBLIC_DEMO_BOOKING_URL="https://calendly.com/agentpilot/agentpilotdemo"
PERPLEXITY_API_KEY="pplx-..."
# Optional: seller company for account research (AI uses "our" name/website in prompts).
# Name and website are taken from the company setup flow (Content Library / User profile) when set; these env vars are fallback only.
SELLER_COMPANY_NAME=""
SELLER_COMPANY_WEBSITE=""
SELLER_COMPANY_DESCRIPTION=""

# Firecrawl: for Content Library "Import from URL" and site map / scrape
FIRECRAWL_API_KEY="fc-your-api-key"

# Exa: realtime account signals (news, earnings, executive changes). Optional; cron skips when unset.
EXA_API_KEY=""

# Content Library: canonical product site for health recommendations (e.g. https://www.agentpilot.us).
# If set, "Top recommendations" and suggested crawl URLs use this origin instead of the first stored sourceUrl.
# Prevents staging URL (e.g. revenue-agents.vercel.app) from appearing in recommendations.
CONTENT_LIBRARY_PRODUCT_ORIGIN=""

# Vercel: sales page deployment from chat (deploy_sales_page_to_vercel, deploy_custom_landing_page).
# Create token at https://vercel.com/account/tokens
# For production (e.g. agentpilot.us): add VERCEL_ACCESS_TOKEN in Vercel project Settings → Environment Variables.
VERCEL_ACCESS_TOKEN=""
# Optional: deploy to a specific team/project (e.g. one that has agentpilot.us custom domain).
# VERCEL_TEAM_ID="team_xxx"
# VERCEL_PROJECT_ID="prj_xxx"

# Vercel Blob: for Content Library file uploads (optional; uploads work without it but files are not stored in Blob)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# CRM (optional): Import contacts and push activities
# HubSpot: Private app access token (Scopes: crm.objects.contacts.read, crm.objects.companies.read, crm.objects.emails.write, crm.objects.meetings.write)
HUBSPOT_API_KEY=""
# Salesforce: Access token and instance URL (e.g. from Connected App or OAuth)
SALESFORCE_ACCESS_TOKEN=""
SALESFORCE_INSTANCE_URL="https://yourorg.my.salesforce.com"
# Optional: custom field API names for segment/buying group (e.g. AgentPilot_Segment__c). Import reads these; push writes segment data.
SALESFORCE_ACCOUNT_SEGMENT_FIELD=""
SALESFORCE_CONTACT_SEGMENT_FIELD=""

# Cron
CRON_SECRET="generate_random_string_here"

# Public URL (for deployment)
NEXT_PUBLIC_URL="http://localhost:3000"

# StradexAI → AgentPilot free account brief
# POST /api/stradex/lead-brief (initial) · POST /api/stradex/lead-brief/supplement (optional follow-up fields)
#
# Service user: a normal User row in the DB (e.g. accountStatus=active) used only for Stradex-owned
# companies so ops can filter in AgentPilot. Set exactly one of:
# STRADEX_LEAD_BRIEF_USER_ID="cuid"
# STRADEX_LEAD_BRIEF_USER_EMAIL="ops@yourcompany.com"
#
# Optional: Bearer or x-stradex-lead-secret for webhooks / cross-origin server calls
# STRADEX_LEAD_BRIEF_SECRET="long_random_string"
# Allowed browser Origins when secret not used (comma-separated); defaults to NEXTAUTH_URL if unset
# STRADEX_LEAD_ALLOWED_ORIGINS="https://app.agentpilot.us,https://www.stradexai.com"
# Rate limit (per IP) — main form
# STRADEX_LEAD_BRIEF_MAX_PER_IP=5
# STRADEX_LEAD_BRIEF_WINDOW_SECONDS=3600
# Supplement endpoint: primary limit per submitter email, secondary per IP (brute-force / shared NAT)
# STRADEX_LEAD_SUPPLEMENT_MAX_PER_EMAIL=10
# STRADEX_LEAD_SUPPLEMENT_MAX_PER_IP=40
#
# Confirmation email (Resend; requires RESEND_API_KEY). Set STRADEX_LEAD_SEND_CONFIRMATION_EMAIL=false to disable.
# STRADEX_LEAD_FROM_EMAIL="StradexAI <hello@stradexai.com>"
#
# Thin enrichment → manual review (skip auto drafts + shared briefing if below thresholds)
# STRADEX_BRIEF_MIN_SIGNALS=3
# STRADEX_BRIEF_MIN_CONTACTS=2
#
# Enrichment caps (free brief tier — lower cost)
# STRADEX_BRIEF_MAX_PEOPLE=8
# STRADEX_BRIEF_SIGNAL_HOURS=72
# STRADEX_BRIEF_MAX_SIGNALS=12
# STRADEX_BRIEF_SKIP_WEBSET=true
# STRADEX_BRIEF_SKIP_LLM_DRAFTS=false
# STRADEX_BRIEF_RUN_BUYING_GROUPS=false
# Premium delivery: time-boxed /go/briefing/{token} (recommended for wow). PDF/email can be fallback.
# STRADEX_BRIEF_CREATE_SHARE_LINK=true
