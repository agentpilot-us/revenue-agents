{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    { "path": "/api/cron/calculate-engagement", "schedule": "0 2 * * *" },
    { "path": "/api/cron/aggregate-analytics", "schedule": "0 1 * * *" },
    { "path": "/api/cron/content-library/run-schedules", "schedule": "0 3 * * *" },
    { "path": "/api/cron/fetch-account-signals", "schedule": "0 */2 * * *" },
    { "path": "/api/cron/send-alert-digest", "schedule": "0 21 * * *" },
    { "path": "/api/cron/process-scheduled-actions", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/advance-sequences", "schedule": "0 * * * *" },
    { "path": "/api/cron/play-timeline-triggers", "schedule": "0 4 * * *" },
    { "path": "/api/cron/play-crm-field-gates", "schedule": "0 4 * * *" },
    { "path": "/api/cron/action-workflow-triggers", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/contact-touch-cleanup", "schedule": "0 11 * * 0" },
    { "path": "/api/cron/flag-stale-play-runs", "schedule": "0 13 * * *" },
    { "path": "/api/cron/refresh-account-research", "schedule": "0 10 * * 6" }
  ]
}
