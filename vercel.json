{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    { "path": "/api/cron/calculate-engagement", "schedule": "0 2 * * *" },
    { "path": "/api/cron/aggregate-analytics", "schedule": "0 1 * * *" },
    { "path": "/api/cron/content-library/run-schedules", "schedule": "0 3 * * *" },
    { "path": "/api/cron/fetch-account-signals", "schedule": "0 */6 * * *" },
    { "path": "/api/cron/send-alert-digest", "schedule": "0 14 * * *" },
    { "path": "/api/cron/process-scheduled-actions", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/advance-sequences", "schedule": "0 * * * *" }
  ]
}
